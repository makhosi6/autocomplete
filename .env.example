# ===========================================
# Autocomplete API - Environment Variables
# ===========================================
# Copy to .env and customize

# --- Application ---
PORT=3001

# --- Admin (for secret routes and data loading) ---
ADMIN_KEY=A8E6YziXl3RmoYAq1LjIH8f8LZtEbrDDsOEqAs8i

# --- Redis (words/autocomplete) ---
# Docker: redis_words | Local: 127.0.0.1
REDIS_HOST=redis_words
REDIS_PORT=6379
REDIS_PASSWORD=xy5rgQdRgu7NTtK
# Or override with full URL: redis://:password@host:port/0
# REDIS_URL=redis://:xy5rgQdRgu7NTtK@127.0.0.1:6379/0

# --- Redis Auth (rate limiting) ---
# Docker: redis_auth | Local: 127.0.0.1
REDIS_AUTH_HOST=redis_auth
REDIS_AUTH_PORT=6379

# --- Docker: external port mapping ---
REDIS_WORDS_PORT=6379
REDIS_AUTH_PORT_EXTERNAL=6380
REDIS_INSIGHT_PORT=5540

# --- Nginx ---
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# --- Local dev (connect to Docker Redis from host) ---
# REDIS_HOST=127.0.0.1 REDIS_AUTH_HOST=127.0.0.1 REDIS_AUTH_PORT=6380 npm run dev
